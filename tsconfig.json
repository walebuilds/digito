{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "lib":              ["ES2020", "DOM"],
    "outDir":           "./dist",
    "rootDir":          "./src",
    "declaration":      true,
    "declarationMap":   true,
    "sourceMap":        true,
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "jsx":              "react-jsx"
  },
  "files": [
    "src/index.ts",
    "src/core/index.ts",
    "src/adapters/vanilla.ts",
    "src/adapters/alpine.ts",
    "src/adapters/web-component.ts"
  ],
  "exclude": ["node_modules", "dist", "examples"]
}
